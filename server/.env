# 羽翼Pro V2 - 环境变量配置示例
# 复制此文件为 .env 并填入真实的API密钥

# ==================== NanoBanana API配置 ====================
# 图片生成API（Fal.ai平台）
# 获取方式：联系热梦百科API平台 https://api.remenbaike.com
NANOBANANA_API_KEY=your_api_key_here
NANOBANANA_API_BASE_URL=https://api.remenbaike.com

# ==================== Kling API配置 ====================
# 图生视频API
# 使用相同的API Key即可
KLING_API_KEY=your_api_key_here
KLING_API_BASE_URL=https://api.remenbaike.com

# ==================== Ark Seedance/Seedream 配置 ====================
# 火山引擎 Ark Key，用于 Seedream 出图 / Seedance 图生视频
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 默认切到 Ark 视频模型
VIDEO_PROVIDER=seedance
SEEDANCE_MODEL=doubao-seedance-1-0-pro-250528
SEEDANCE_DEFAULT_RESOLUTION=1080p
SEEDANCE_DEFAULT_CAMERA_FIXED=false
SEEDANCE_DEFAULT_WATERMARK=true

# ==================== 阿里云百炼 (Qwen) ====================
# 千问官网 API，图文AI制作等使用
# 获取方式：https://dashscope.aliyun.com/
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-max

# ==================== 可选：AI评分服务 ====================
# GPT-4 Vision API（用于图片质量评分）
# 如果不配置，将使用占位评分系统
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# ==================== 可选：提示词优化服务 ====================
# GPT-4 API（用于提示词优化）
# 如果不配置，将使用规则优化系统
# PROMPT_OPTIMIZER_API_KEY=sk-...

# ==================== Web服务器配置 ====================
# 端口（默认8080）
# WEB_PORT=8080

# 主机（默认0.0.0.0，允许外部访问）
# WEB_HOST=0.0.0.0

# ==================== 日志配置 ====================
# 日志级别（DEBUG/INFO/WARNING/ERROR）
# LOG_LEVEL=INFO
